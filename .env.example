# Supabase
# Found in: Supabase dashboard → Project Settings → API Keys
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Supabase Postgres connection string (used by PowerSync for logical replication)
# Found in: Supabase dashboard → Project Settings → Database → Connection string (URI mode)
SUPABASE_DB_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# PowerSync (self-hosted)
# POWERSYNC_URL: the address of your running PowerSync Docker instance
POWERSYNC_URL=http://localhost:8080

# Supabase JWKS endpoint — used by PowerSync for RS256 JWT validation (no shared secret needed)
# Format: https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWKS_URL=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json

# Production: domain for Caddy HTTPS reverse proxy (used by docker-compose.prod.yml)
CADDY_DOMAIN=powersync.yourdomain.com

# Dev bootstrap test user (created by dev/bootstrap.ts)
BOOTSTRAP_USER_EMAIL=test@brainfence.dev
BOOTSTRAP_USER_PASSWORD=
