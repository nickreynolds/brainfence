# Supabase
# Found in: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Postgres connection string (used by PowerSync for logical replication)
# Found in: Supabase dashboard → Project Settings → Database → Connection string (URI mode)
SUPABASE_DB_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# PowerSync (self-hosted)
# POWERSYNC_URL: the address of your running PowerSync Docker instance
# JWT validation uses Supabase's JWKS endpoint (derived from SUPABASE_URL) — no separate secret needed
POWERSYNC_URL=http://localhost:8080

# Dev bootstrap test user (created by dev/bootstrap.ts)
BOOTSTRAP_USER_EMAIL=test@brainfence.dev
BOOTSTRAP_USER_PASSWORD=
